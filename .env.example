# ── Caminhos (obrigatório) ────────────────────────────────────────────────────
BASTION_WIKI_PATH=/absolute/path/to/wiki
BASTION_RAW_PATH=/absolute/path/to/raw
BASTION_DB_PATH=/absolute/path/to/data/bastion.sqlite

# ── Servidor ──────────────────────────────────────────────────────────────────
BASTION_BACKEND_PORT=8080           # opcional, default 8080
BASTION_GIT_AUTHOR_NAME=Bastion     # opcional
BASTION_GIT_AUTHOR_EMAIL=bastion@local

# ── API Keys (opcional via .env — pode ser configurado na UI em /settings) ────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
VOYAGE_API_KEY=

# ── Provider default (opcional — pode ser configurado na UI em /settings) ─────
BASTION_LLM_PROVIDER=              # openai | anthropic | openrouter | gemini
BASTION_LLM_MODEL=                 # vazio = default do provider
BASTION_EMBED_PROVIDER=            # openai | voyage | gemini
BASTION_EMBED_MODEL=               # vazio = default
